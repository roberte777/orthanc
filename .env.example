# Orthanc Server Configuration
# Copy this file to .env and adjust values as needed

# Database Configuration
DATABASE_URL=sqlite:./orthanc.db
DATABASE_MAX_CONNECTIONS=10
DATABASE_MIN_CONNECTIONS=2
DATABASE_CONNECT_TIMEOUT=30
DATABASE_MAX_LIFETIME=1800
DATABASE_ENABLE_WAL=true

# Logging Configuration
# Available levels: trace, debug, info, warn, error
# Format: module=level,level
RUST_LOG=orthanc_server=debug,info

# Server Configuration
SERVER_ADDR=0.0.0.0:8080

# Authentication
JWT_SECRET=change-this-to-a-long-random-secret-in-production
ACCESS_TOKEN_EXPIRY=900
REFRESH_TOKEN_EXPIRY=2592000

# Media Library Paths (to be used in future)
# MEDIA_LIBRARY_MOVIES=/path/to/movies
# MEDIA_LIBRARY_TV=/path/to/tv

# Transcoding Configuration (to be used in future)
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe
# TRANSCODE_TEMP_DIR=/tmp/orthanc/transcode

# Metadata Providers (optional — a default TMDB key is built in)
# TMDB_API_KEY=your_tmdb_api_key_here

# Image Cache
IMAGE_CACHE_DIR=./image_cache
